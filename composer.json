{
  "name": "test-egitim/platform",
  "description": "Düz PHP test ve eğitim platformu",
  "type": "project",
  "require": {
    "php": ">=8.1",
    "mpdf/mpdf": "^8.2"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    },
    "files": [
      "src/config.php",
      "src/helpers.php",
      "src/db.php",
      "src/auth.php",
      "src/csrf.php"
    ]
  },
  "config": {
    "allow-plugins": {
      "php-http/discovery": true
    }
  }
}
