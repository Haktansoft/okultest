.env.production

# Composer — paylaşımlı hosting'de SSH/composer yoksa, vendor'ı tracked yapabilirsin.
# Şu an tracked: deploy'da otomatik gelir.
# /vendor/

# Yüklenen medya (sunucuda canlı veri)
/storage/uploads/images/*
/storage/uploads/audios/*
/storage/uploads/videos/*
!/storage/uploads/images/.gitkeep
!/storage/uploads/audios/.gitkeep
!/storage/uploads/videos/.gitkeep

